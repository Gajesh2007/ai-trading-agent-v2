# === LLM Providers (at least one required) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# === Default Model (used for all roles unless overridden) ===
MODEL_PROVIDER=anthropic
MODEL_ID=claude-sonnet-4-20250514

# === Per-Role Model Overrides (optional) ===
# MODEL_EVALUATOR_PROVIDER=anthropic
# MODEL_EVALUATOR_ID=claude-opus-4-6
# MODEL_THESISVALIDATOR_PROVIDER=openrouter
# MODEL_THESISVALIDATOR_ID=arcee-ai/trinity-large-thinking
# MODEL_ANALYSTA_PROVIDER=anthropic
# MODEL_ANALYSTA_ID=claude-opus-4-6
# MODEL_ANALYSTB_PROVIDER=openai
# MODEL_ANALYSTB_ID=gpt-5.4
# MODEL_ANALYSTC_PROVIDER=openrouter
# MODEL_ANALYSTC_ID=arcee-ai/trinity-large-thinking

# === Web Search (optional — enhances agent research) ===
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# === Kalshi (optional — system works without it) ===
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PEM=

# === Paper Trading (default: on) ===
PAPER_TRADING=true
PAPER_STARTING_EQUITY=200

# === Hyperliquid Execution (required for live trading only) ===
HL_PRIVATE_KEY=
HL_WALLET_ADDRESS=

# === Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# === Timing ===
DISCOVERY_INTERVAL_MS=900000
